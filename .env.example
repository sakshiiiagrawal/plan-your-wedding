# ===================================================
# Wedding Planner — Environment Variables
# Copy this file to api/.env and fill in your values.
# Run `npm run setup` to do this interactively.
# ===================================================

# -------------------- Supabase --------------------
# Your Supabase project URL (from Project Settings > API)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key — KEEP SECRET, server-side only
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Supabase anon/public key — used by API + frontend
SUPABASE_ANON_KEY=your-anon-key-here

# -------------------- Auth (JWT) ------------------
# JWT signing secret — must be at least 32 characters
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# -------------------- Server ----------------------
NODE_ENV=development
PORT=3001

# -------------------- Frontend (optional) ---------
# Set in production to your deployed frontend URL
FRONTEND_URL=http://localhost:5173

# -------------------- Database (optional) ---------
# Required for `npm run db:migrate` (direct postgres access).
# Format: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# Leave blank to use `npm run db:migrate:print` (copy-paste into Supabase SQL Editor).
DATABASE_URL=
