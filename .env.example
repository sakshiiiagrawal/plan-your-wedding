# ===================================================
# Wedding Planner — Environment Variables
# Copy this file to .env and fill in your values
# ===================================================

# -------------------- Supabase --------------------
# Your Supabase project URL (from Project Settings > API)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key — KEEP SECRET, server-side only
SUPABASE_SERVICE_KEY=your-service-role-key-here

# -------------------- Auth (JWT) ------------------
# JWT signing secret — must be at least 32 characters
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# -------------------- Server ----------------------
NODE_ENV=development
PORT=3001

# -------------------- Frontend (optional) ---------
# Set in production to your deployed frontend URL
FRONTEND_URL=http://localhost:5173

# -------------------- Vite (frontend) -------------
# Public Supabase key — safe to expose client-side
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
