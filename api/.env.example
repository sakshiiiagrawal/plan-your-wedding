PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
# FRONTEND_URL=https://your-frontend.vercel.app  # production

# -------------------- Supabase --------------------
# From your Supabase project: Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# -------------------- Auth (JWT) ------------------
# Must be at least 32 characters. Generate: openssl rand -base64 48
JWT_SECRET=your-jwt-secret-at-least-32-characters-long
JWT_EXPIRES_IN=7d

# -------------------- Database (optional) ---------
# Required for `npm run db:migrate`. Leave blank to use Supabase SQL Editor.
# Format: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://user:password@host:5432/database

# -------------------- Email (optional) ------------
# Unset in dev: emails print to the console instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Wedding Planner <no-reply@example.com>

# -------------------- Places / Geocoding (optional) --------------------
# Google Places API (New) — tried first for venue address search when set;
# falls back to Mappls (MAPPLS_CLIENT_ID/SECRET) then Photon (no key needed).
GOOGLE_PLACES_API_KEY=
