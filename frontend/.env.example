# Local development
VITE_API_URL=http://localhost:3001/api/v1

# For production (replace with your backend Vercel URL)
# VITE_API_URL=https://your-backend-name.vercel.app/api/v1

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Address autocomplete uses Photon (OpenStreetMap-based, free, no API key).
# Override the endpoint here if you self-host Photon: https://github.com/komoot/photon
# VITE_PHOTON_ENDPOINT=https://photon.komoot.io/api/

# -------------------- Analytics (Mixpanel) --------------------
# Project token from Mixpanel > Settings > Project Settings.
# Tracking is off unless VITE_TRACK_EVENTS=true and the token is a real one.
VITE_MIXPANEL_TOKEN=your-mixpanel-project-token
VITE_TRACK_EVENTS=false
# Set to true for Mixpanel's verbose console logging in development
# VITE_DEBUG=false
